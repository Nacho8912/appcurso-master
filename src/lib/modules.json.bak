        "type": "code",
        "language": "python",
        "code": "# Datos de entrada\ninversion_publicitaria    = 5000.0\nclientes_adquiridos       = 120\nvalor_promedio_cliente    = 150.0\ncosto_por_cliente         = 20.0\n\n# Cálculos\ningresos_totales  = clientes_adquiridos * valor_promedio_cliente\ncostos_operativos = clientes_adquiridos * costo_por_cliente\ncostos_totales    = inversion_publicitaria + costos_operativos\nbenefico_neto     = ingresos_totales - costos_totales\nroi_porcentaje    = (beneficio_neto / inversion_publicitaria) * 100\n\n# Resultados\nprint(f\"Ingresos totales: €{ingresos_totales}\")\nprint(f\"Costos totales:   €{costos_totales}\")\nprint(f\"Beneficio neto:   €{beneficio_neto}\")\nprint(f\"ROI: {roi_porcentaje:.2f}%\")  # :.2f = float con 2 decimales",
        "caption": "Crea calculadora_roi.py. Antes de ejecutar, predice mentalmente: ¿el ROI será positivo o negativo?"
