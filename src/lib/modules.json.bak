      {
        "type": "code",
        "language": "python",
        "code": "print(\"=== AGENTE DE ELEGIBILIDAD DE PRÉSTAMO ===\\n\")\n\ningreso_mensual      = float(input(\"Ingreso mensual neto (€): \"))\nedad                 = int(input(\"Edad: \"))\ntiene_empleo_fijo    = input(\"¿Empleo fijo? (s/n): \").lower() == 's'\ndeuda_actual         = float(input(\"Deuda actual mensual (€): \"))\nhistorial_crediticio = int(input(\"Puntuación historial crediticio (0-100): \"))\n\nratio_deuda_ingreso = (deuda_actual / ingreso_mensual) * 100 if ingreso_mensual > 0 else 100\n\n# Criterios individuales\ningreso_suficiente = ingreso_mensual >= 1200\nedad_adecuada      = 18 <= edad <= 65\ndeuda_controlada   = ratio_deuda_ingreso < 40\nhistorial_bueno    = historial_crediticio >= 70\n\naprobado_basico   = ingreso_suficiente and edad_adecuada and tiene_empleo_fijo\naprobado_premium  = aprobado_basico and deuda_controlada and historial_bueno\n\nif aprobado_premium:\n    print(\"\\n✅ PRÉSTAMO APROBADO - Condiciones Premium (3.5% anual)\")\nelif aprobado_basico:\n    print(\"\\n⚠️ PRÉSTAMO APROBADO - Condiciones Estándar (6.5% anual)\")\nelse:\n    print(\"\\n❌ PRÉSTAMO RECHAZADO\")\n    if not ingreso_suficiente: print(\"- Ingreso insuficiente (mínimo €1,200)\")\n    if not edad_adecuada:      print(\"- Edad fuera de rango (18-65 años)\")\n    if not tiene_empleo_fijo:  print(\"- Se requiere empleo fijo\")",
        "caption": "Crea elegibilidad_prestamo.py. Observa cómo las condiciones complejas se descomponen en variables con nombres descriptivos."
