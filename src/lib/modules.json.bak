      {
        "type": "code",
        "language": "python",
        "code": "from typing import List, Callable\nfrom dataclasses import dataclass\n\n@dataclass\nclass Lead:\n    nombre: str; empresa: str; presupuesto: float\n    urgencia: int; sector: str  # urgencia: 1-5\n\ndef filtrar_por_criterio(leads: List[Lead], criterio: Callable) -> List[Lead]:\n    return [l for l in leads if criterio(l)]\n\ndef ordenar_por_prioridad(leads: List[Lead]) -> List[Lead]:\n    \"\"\"Urgencia desc, luego presupuesto desc.\"\"\"\n    return sorted(leads, key=lambda l: (-l.urgencia, -l.presupuesto))\n\n# Uso\nleads = [\n    Lead(\"Ana García\",   \"TechCorp\",   50000, 5, \"tecnología\"),\n    Lead(\"Luis Martínez\",\"ConsultoraX\",15000, 3, \"consultoría\"),\n    Lead(\"Carmen Ruiz\",  \"StartupY\",    8000, 5, \"tecnología\"),\n    Lead(\"David López\",  \"EnterpriseZ\",120000,2, \"finanzas\"),\n]\n\nurgentes    = filtrar_por_criterio(leads, lambda l: l.urgencia >= 4)\ntech_alto   = filtrar_por_criterio(leads, lambda l: l.presupuesto > 30000 and l.sector == \"tecnología\")\nprioridad   = ordenar_por_prioridad(leads)\n\npresupuestos = [l.presupuesto for l in leads]\nprint(f\"Total: €{sum(presupuestos):,} | Promedio: €{sum(presupuestos)/len(presupuestos):,.0f}\")",
        "caption": "Crea filtrado_leads.py. La comprensión de lista con criterio lambda es el patrón 'filter funcional'."
      },
