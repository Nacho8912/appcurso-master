      },
      {
        "type": "code",
        "language": "python",
        "code": "def nombre_funcion():\n    # Cuerpo indentado: cero o más líneas de lógica\n    print(\"Esta función no hace nada útil aún\")\n    # Sin return: devuelve None implícitamente\n\nnombre_funcion()  # Llamada: ejecuta el cuerpo"
      },
