        "text": "Ejercicio práctico 6: Agente de monitoreo con alertas tempranas"
      },
      {
        "type": "code",
        "language": "python",
        "code": "import random\n\nprint(\"=== AGENTE DE MONITOREO DE SERVIDORES ===\")\n\nmetricas_nodos = [\n    {\"nodo\": f\"SRV-{i+1:03d}\", \"cpu\": random.randint(20, 95), \"memoria\": random.randint(30, 90)}\n    for i in range(10)\n]\n\nnodo_critico = None\n\nfor nodo in metricas_nodos:\n    print(f\"Revisando {nodo['nodo']}: CPU {nodo['cpu']}%, MEM {nodo['memoria']}%\")\n    \n    if nodo[\"cpu\"] > 90 or nodo[\"memoria\"] > 85:\n        nodo_critico = nodo\n        print(f\"\\n🔴 ALERTA CRÍTICA: {nodo['nodo']}\")\n        break\nelse:\n    print(f\"\\n🟢 Todos los nodos operan normalmente\")\n\n# Análisis secundario con continue\nif nodo_critico is None:\n    for nodo in metricas_nodos:\n        if nodo[\"cpu\"] < 50 and nodo[\"memoria\"] < 50:\n            continue  # Nodo eficiente, no requiere acción\n        print(f\"⚠️  {nodo['nodo']}: Considerar optimización\")",
        "caption": "Crea monitoreo_sistemas.py. Combina break para alerta crítica, else de bucle para estado OK, y continue para filtrar nodos eficientes."
      },
