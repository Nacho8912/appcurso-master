          ]
        ]
      },
      {
        "type": "code",
        "language": "python",
        "code": "# agente_reservas_modular.py — Arquitectura Modular v2.0\n\nfrom dataclasses import dataclass\nfrom typing import List, Optional, Tuple\n\n# === CONFIGURACIÓN ===\nclass Config:\n    CAPACIDAD_MESAS    = 10\n    HORARIO_APERTURA   = 13\n    HORARIO_CIERRE     = 22\n    PRECIO_MENU        = 35.0\n    DESCUENTO_TEMPRANO = 0.10\n    UMBRAL_VIP         = 4\n\n# === ESTRUCTURA DE DATOS ===\n@dataclass\nclass Reserva:\n    mesa: int; cliente: str; comensales: int; hora: int\n    es_vip: bool; costo_base: float; descuento: float; costo_final: float\n    \n    def resumen(self):\n        vip = \" [VIP]\" if self.es_vip else \"\"\n        return f\"{self.hora:02d}:00 Mesa {self.mesa}{vip}: {self.cliente} ({self.comensales}p) €{self.costo_final:.2f}\"\n\n# === FUNCIONES PURAS ===\ndef calcular_costo(comensales: int, hora: int) -> Tuple[float, float]:\n    \"\"\"Retorna (costo_base, descuento).\"\"\"\n    base = comensales * Config.PRECIO_MENU\n    desc = base * Config.DESCUENTO_TEMPRANO if hora < 18 else 0.0\n    return base, desc\n\ndef es_mesa_vip(comensales: int) -> bool:\n    return comensales > Config.UMBRAL_VIP\n\n# === I/O AISLADO ===\ndef solicitar_datos() -> Optional[dict]:\n    nombre = input(\"\\nCliente (Enter para terminar): \").strip().title()\n    if not nombre: return None\n    \n    while True:\n        try:\n            c = int(input(\"Comensales (1-8): \"))\n            if 1 <= c <= 8: break\n        except ValueError: pass\n        print(\"Rango 1-8\")\n    \n    while True:\n        try:\n            h = int(input(f\"Hora ({Config.HORARIO_APERTURA}-{Config.HORARIO_CIERRE-1}): \"))\n            if Config.HORARIO_APERTURA <= h < Config.HORARIO_CIERRE: break\n        except ValueError: pass\n        print(\"Hora fuera de rango\")\n    \n    return {\"nombre\": nombre, \"comensales\": c, \"hora\": h}\n\ndef mostrar_reporte(reservas: List[Reserva]) -> None:\n    if not reservas:\n        print(\"No se realizaron reservas\")\n        return\n    total = sum(r.costo_final for r in reservas)\n    print(f\"\\n{'='*50}\\nRESUMEN: {len(reservas)} reservas | €{total:.2f} ingresos\")\n    for r in sorted(reservas, key=lambda x: x.hora):\n        print(f\"  {r.resumen()}\")\n\n# === ORQUESTADOR ===\ndef ejecutar_turno() -> List[Reserva]:\n    mesas_libres = list(range(1, Config.CAPACIDAD_MESAS + 1))\n    reservas: List[Reserva] = []\n    \n    print(\"=\" * 50)\n    print(\"AGENTE DE RESERVAS v2.0 — ARQUITECTURA MODULAR\")\n    \n    while mesas_libres:\n        datos = solicitar_datos()         # Impura: I/O\n        if datos is None: break\n        \n        base, desc = calcular_costo(datos[\"comensales\"], datos[\"hora\"])  # Pura\n        vip  = es_mesa_vip(datos[\"comensales\"])                          # Pura\n        mesa = mesas_libres.pop(0)\n        \n        r = Reserva(mesa, datos[\"nombre\"], datos[\"comensales\"],\n                    datos[\"hora\"], vip, base, desc, base-desc)\n        reservas.append(r)\n        print(f\"\\n✅ {r.resumen()}\")\n        \n        if not mesas_libres: break\n        if input(\"¿Otra? (s/n): \").lower() != 's': break\n    \n    mostrar_reporte(reservas)             # Impura: output\n    return reservas\n\nif __name__ == \"__main__\":\n    ejecutar_turno()",
        "caption": "Guarda como agente_reservas_modular.py. Compara la legibilidad del orquestador con el monolito del Módulo 1."
      },
