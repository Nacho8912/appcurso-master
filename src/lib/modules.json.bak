          ]
        ]
      },
      {
        "type": "alert",
        "variant": "warning",
        "text": "Principio de Sustitución de Liskov (LSP): Las subclases deben poder sustituir a sus padres sin alterar la corrección. Un Cuadrado matemáticamente ES un Rectángulo, pero en POO viola LSP si set_ancho cambia tanto ancho como alto. Regla: si no puedes decir 'X es un tipo de Y' sin forzar la voz, usa composición."
      },
      {
        "type": "alert",
        "variant": "info",
        "text": "Inversión de Dependencias (DIP): Depende de abstracciones, no de concreciones. Malo: ProcesadorPedidos(self) crea MySQLDatabase() directamente. Bueno: ProcesadorPedidos(self, db: Database, notificador: Notificador) — la clase recibe sus dependencias por parámetro (inyección de dependencias)."
      },
      {
        "type": "heading",
        "level": 2,
        "text": "Submódulo 4.10: Proyecto del Módulo — Framework de Agentes Modular"
      },
      {
        "type": "code",
        "language": "python",
        "code": "# framework_agentes.py — Framework completo integrando todos los conceptos\nfrom __future__ import annotations\nfrom abc import ABC, abstractmethod\nfrom typing import Dict, List, Optional, Callable, Any\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\nfrom enum import Enum, auto\nimport uuid\n\nclass EstadoTarea(Enum):\n    PENDIENTE = auto(); EN_PROGRESO = auto()\n    COMPLETADA = auto(); FALLIDA = auto()\n\n@dataclass\nclass Tarea:\n    id:     str  = field(default_factory=lambda: str(uuid.uuid4())[:8])\n    tipo:   str  = \"\"\n    datos:  Dict = field(default_factory=dict)\n    estado: EstadoTarea = EstadoTarea.PENDIENTE\n    resultado: Optional[Any] = None\n    iniciada:  Optional[datetime] = None\n    completada: Optional[datetime] = None\n\n@dataclass\nclass MemoriaEpisodica:\n    timestamp: datetime; contexto: str\n    entrada: str; accion: str; resultado: str\n    importancia: int = 5\n\nclass MemoriaRAM:\n    def __init__(self): self._eps: List[MemoriaEpisodica] = []\n    def guardar(self, e: MemoriaEpisodica): self._eps.append(e)\n    def recuperar(self, ctx: str, n: int = 5):\n        rel = [e for e in self._eps if ctx in e.contexto]\n        return sorted(rel, key=lambda x: x.importancia, reverse=True)[:n]\n\nclass AgenteInteligente(ABC):\n    \"\"\"Clase base del framework: ciclo de vida, memoria, eventos.\"\"\"\n    \n    def __init__(self, nombre: str, memoria: MemoriaRAM, config: Dict = None):\n        self.id      = str(uuid.uuid4())[:12]\n        self.nombre  = nombre\n        self.memoria = memoria\n        self.config  = config or {}\n        self._estado = \"inicializado\"\n        self._completadas: List[Tarea] = []\n        self._hooks: Dict[str, List[Callable]] = {}\n    \n    def on(self, evento: str, cb: Callable):\n        self._hooks.setdefault(evento, []).append(cb)\n    \n    def _emit(self, evt: str, datos: dict):\n        for cb in self._hooks.get(evt, []):\n            try: cb(datos)\n            except: pass\n    \n    @abstractmethod\n    def interpretar(self, entrada: str) -> Dict: pass\n    @abstractmethod\n    def planificar(self, intencion: Dict) -> List[Tarea]: pass\n    @abstractmethod\n    def ejecutar_tarea(self, tarea: Tarea) -> Any: pass\n    @abstractmethod\n    def sintetizar(self, resultados: List[Any]) -> str: pass\n    \n    def procesar(self, entrada: str, contexto: str = \"general\") -> Dict:\n        \"\"\"Pipeline completo: interpretar → planificar → ejecutar → sintetizar → memorizar.\"\"\"\n        self._estado = \"procesando\"\n        self._emit(\"inicio\", {\"entrada\": entrada})\n        \n        intencion = self.interpretar(entrada)\n        plan      = self.planificar(intencion)\n        resultados = []\n        \n        for t in plan:\n            t.estado = EstadoTarea.EN_PROGRESO; t.iniciada = datetime.now()\n            r = self.ejecutar_tarea(t)\n            t.resultado = r; t.estado = EstadoTarea.COMPLETADA\n            t.completada = datetime.now()\n            resultados.append(r); self._completadas.append(t)\n        \n        respuesta = self.sintetizar(resultados)\n        self.memoria.guardar(MemoriaEpisodica(\n            timestamp=datetime.now(), contexto=contexto,\n            entrada=entrada, accion=str([t.tipo for t in plan]),\n            resultado=respuesta[:200]\n        ))\n        self._estado = \"listo\"\n        self._emit(\"fin\", {\"respuesta\": respuesta})\n        return {\"respuesta\": respuesta, \"tareas\": len(plan)}\n    \n    def __repr__(self) -> str:\n        return f\"{type(self).__name__}(id={self.id[:8]}, nombre='{self.nombre}', estado='{self._estado}')\"\n\n# Implementación concreta: Agente de Soporte\nclass AgenteSoporte(AgenteInteligente):\n    def __init__(self, memoria: MemoriaRAM):\n        super().__init__(\"Soporte-Técnico\", memoria)\n        self._kb = {\n            \"password\": \"Resetea tu contraseña en /reset-password\",\n            \"lento\":    \"Limpia caché o contacta soporte@empresa.com\",\n            \"error\":    \"Describe el error; revisamos logs de inmediato\"\n        }\n    \n    def interpretar(self, entrada: str) -> Dict:\n        e = entrada.lower()\n        if any(w in e for w in [\"password\", \"contraseña\"]): return {\"tipo\": \"password\", \"urgencia\": 7}\n        if any(w in e for w in [\"lento\", \"carga\"]):         return {\"tipo\": \"lento\", \"urgencia\": 4}\n        return {\"tipo\": \"error\", \"urgencia\": 9}\n    \n    def planificar(self, intencion: Dict) -> List[Tarea]:\n        tareas = [Tarea(tipo=\"buscar_kb\", datos={\"tipo\": intencion[\"tipo\"]})]\n        if intencion[\"urgencia\"] > 7:\n            tareas.append(Tarea(tipo=\"escalar\", datos={\"prioridad\": \"alta\"}))\n        return tareas\n    \n    def ejecutar_tarea(self, t: Tarea) -> Any:\n        if t.tipo == \"buscar_kb\":\n            return self._kb.get(t.datos[\"tipo\"], \"No encontrado. Contacta soporte.\")\n        if t.tipo == \"escalar\":\n            return f\"Ticket ESC-{uuid.uuid4().hex[:6]} creado (prioridad alta)\"\n    \n    def sintetizar(self, resultados: List[Any]) -> str:\n        return \"\\n\\n\".join(str(r) for r in resultados if r)\n\n# Demostración del framework\nprint(\"=\" * 60)\nprint(\"FRAMEWORK DE AGENTES MODULAR\")\nprint(\"=\" * 60)\n\nmemoria = MemoriaRAM()\nagente  = AgenteSoporte(memoria)\n\nagente.on(\"inicio\", lambda d: print(f\"[PROCESANDO] '{d['entrada'][:40]}...'\" ))\nagente.on(\"fin\",    lambda d: print(f\"[LISTO]\\n{d['respuesta']}\\n\"))\n\nprint(f\"\\nAgente creado: {agente!r}\\n\")\n\nfor entrada in [\"Olvidé mi contraseña\", \"El sistema está muy lento\"]:\n    print(\"-\" * 40)\n    res = agente.procesar(entrada)\n    print(f\"Tareas ejecutadas: {res['tareas']}\")\n\nprint(f\"\\nTotal completadas: {len(agente._completadas)}\")",
        "caption": "Crea framework_agentes.py. El patrón: clase base abstracta (AgenteInteligente) define el pipeline; subclases (AgenteSoporte) implementan los detalles. Nuevos tipos de agente no modifican el framework."
      },
