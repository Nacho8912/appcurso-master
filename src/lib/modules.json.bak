      {
        "type": "code",
        "language": "python",
        "code": "# agente_reservas.py — Agente de Gestión de Reservas v1.0\n\nCAPACIDAD_MESAS   = 10\nHORARIO_APERTURA  = 13\nHORARIO_CIERRE    = 22\nPRECIO_MENU       = 35.0\nDESCUENTO_TEMPRANO = 0.10\n\nmesas_disponibles = list(range(1, CAPACIDAD_MESAS + 1))\nreservas = []\n\nprint(\"=\" * 60)\nprint(\"AGENTE DE RESERVAS - RESTAURANTE LA ESQUINA\")\nprint(\"=\" * 60)\n\nwhile mesas_disponibles:\n    nombre = input(\"\\nNombre del cliente (vacío para finalizar): \").strip().title()\n    if not nombre:\n        break\n    \n    # Validación de comensales\n    while True:\n        try:\n            comensales = int(input(\"Comensales (1-8): \"))\n            if 1 <= comensales <= 8: break\n            print(\"Error: máximo 8 personas\")\n        except ValueError:\n            print(\"Error: introduce un número\")\n    \n    # Validación de hora\n    while True:\n        try:\n            hora = int(input(f\"Hora ({HORARIO_APERTURA}-{HORARIO_CIERRE-1}): \"))\n            if HORARIO_APERTURA <= hora < HORARIO_CIERRE: break\n            print(\"Hora fuera de rango\")\n        except ValueError:\n            print(\"Error: introduce hora válida\")\n    \n    # Asignación y cálculo\n    es_vip = comensales > 4\n    mesa   = mesas_disponibles.pop(0)\n    costo_base = comensales * PRECIO_MENU\n    descuento  = costo_base * DESCUENTO_TEMPRANO if hora < 18 else 0\n    costo_final = costo_base - descuento\n    \n    reservas.append({\"mesa\": mesa, \"cliente\": nombre, \"comensales\": comensales,\n                     \"hora\": hora, \"vip\": es_vip, \"costo\": costo_final, \"descuento\": descuento})\n    \n    print(f\"\\n✅ Mesa {mesa}{' (VIP)' if es_vip else ''} — {comensales}p a las {hora}:00 — €{costo_final:.2f}\")\n    \n    if not mesas_disponibles:\n        print(\"🚫 Capacidad máxima alcanzada\")\n        break\n    \n    if input(\"¿Otra reserva? (s/n): \").lower() != 's':\n        break\n\n# Reporte\nif reservas:\n    total     = sum(r[\"costo\"] for r in reservas)\n    descuentos = sum(r[\"descuento\"] for r in reservas)\n    print(f\"\\n{'='*60}\\nRESUMEN: {len(reservas)} reservas | €{total:.2f} ingresos | €{descuentos:.2f} descuentos\")\n    for r in sorted(reservas, key=lambda x: x[\"hora\"]):\n        print(f\"  {r['hora']:02d}:00 Mesa {r['mesa']}: {r['cliente']} ({r['comensales']}p) €{r['costo']:.2f}\")",
        "caption": "Guarda como agente_reservas.py en Modulo_1_ControlFlujo/proyecto/. Combina while, for, break, continue, try/except y comprensiones."
