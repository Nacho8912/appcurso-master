      },
      {
        "type": "alert",
        "variant": "info",
        "text": "La paradoja de la fiabilidad: Añadir mecanismos de resiliencia introduce complejidad que puede ser fuente de nuevos fallos. El Circuit Breaker mal configurado puede cortar servicios sanos; el retry sin idempotencia puede duplicar operaciones. La solución: medir, no asumir. Cada patrón de resiliencia debe tener sus propias métricas y alertas."
      },
      {
        "type": "heading",
        "level": 2,
        "text": "Submódulo 5.10: Proyecto del Módulo — Agente Autorrecuperable"
      },
      {
        "type": "code",
        "language": "python",
        "code": "# agente_autorrecuperable.py — Sistema completo integrando todos los conceptos del módulo\nfrom __future__ import annotations\nimport json, logging, time, random, threading, hashlib\nfrom dataclasses import dataclass, field\nfrom datetime import datetime, timedelta\nfrom enum import Enum, auto\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Callable, Any\n\nlogging.basicConfig(level=logging.INFO,\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s')\nlogger = logging.getLogger(\"agente.autorrecuperable\")\n\nclass EstadoSalud(Enum):\n    SALUDABLE = auto(); DEGRADADO = auto(); CRITICO = auto(); RECUPERANDO = auto()\n\nclass CheckpointManager:\n    def __init__(self, directorio: Path, intervalo_seg: float = 300):\n        self.directorio = Path(directorio); self.directorio.mkdir(parents=True, exist_ok=True)\n        self.intervalo = intervalo_seg\n        self._ultimo: Optional[datetime] = None; self._lock = threading.Lock()\n    \n    def debe_guardar(self) -> bool:\n        if self._ultimo is None: return True\n        return (datetime.now() - self._ultimo).total_seconds() > self.intervalo\n    \n    def guardar(self, id_agente: str, estado: Dict) -> Path:\n        with self._lock:\n            ts = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n            ruta = self.directorio / f\"{id_agente}_{ts}.json\"\n            data = {\"version\": \"2.0\", \"id_agente\": id_agente,\n                   \"timestamp\": datetime.now().isoformat()}\n            json_raw = json.dumps(estado, default=str, sort_keys=True)\n            data[\"checksum\"] = hashlib.sha256(json_raw.encode()).hexdigest()[:16]\n            data[\"estado\"] = estado\n            with open(ruta, \"w\", encoding=\"utf-8\") as f:\n                json.dump(data, f, default=str, indent=2)\n            self._ultimo = datetime.now()\n            logger.info(f\"Checkpoint: {ruta.name}\")\n            # Rotar: mantener solo últimos 10\n            archivos = sorted(self.directorio.glob(f\"{id_agente}_*.json\"),\n                            key=lambda p: p.stat().st_mtime, reverse=True)\n            for a in archivos[10:]: a.unlink()\n            return ruta\n    \n    def cargar_ultimo(self, id_agente: str) -> Optional[Dict]:\n        archivos = sorted(self.directorio.glob(f\"{id_agente}_*.json\"),\n                        key=lambda p: p.stat().st_mtime, reverse=True)\n        if not archivos: return None\n        with open(archivos[0], \"r\", encoding=\"utf-8\") as f:\n            data = json.load(f)\n        checksum_guardado = data[\"checksum\"]\n        json_raw = json.dumps(data[\"estado\"], default=str, sort_keys=True)\n        checksum_actual = hashlib.sha256(json_raw.encode()).hexdigest()[:16]\n        if checksum_actual != checksum_guardado:\n            raise ValueError(\"Checkpoint corrupto\")\n        return data[\"estado\"]\n\nclass CircuitBreakerSimple:\n    def __init__(self, nombre: str, max_fallos: int = 3, tiempo_abierto: float = 5.0):\n        self.nombre = nombre; self.max_fallos = max_fallos\n        self.tiempo_abierto = tiempo_abierto; self.estado = \"cerrado\"\n        self._fallos: List[datetime] = []; self._ultimo_fallo: Optional[datetime] = None\n        self._lock = threading.Lock()\n    \n    def puede_ejecutar(self) -> bool:\n        with self._lock:\n            if self.estado == \"abierto\":\n                if self._ultimo_fallo and (datetime.now() - self._ultimo_fallo).total_seconds() > self.tiempo_abierto:\n                    self.estado = \"semi_abierto\"; logger.info(f\"Circuito {self.nombre}: semi-abierto\")\n                    return True\n                return False\n            return True\n    \n    def exito(self):\n        with self._lock:\n            if self.estado == \"semi_abierto\":\n                self.estado = \"cerrado\"; self._fallos = []\n                logger.info(f\"Circuito {self.nombre}: cerrado\")\n    \n    def fallo(self):\n        with self._lock:\n            self._fallos.append(datetime.now()); self._ultimo_fallo = datetime.now()\n            limite = datetime.now() - timedelta(seconds=60)\n            self._fallos = [f for f in self._fallos if f > limite]\n            if len(self._fallos) >= self.max_fallos and self.estado != \"abierto\":\n                self.estado = \"abierto\"\n                logger.warning(f\"Circuito {self.nombre}: abierto\")\n\nclass AgenteAutorrecuperable:\n    \"\"\"Agente con checkpoint periódico, circuit breaker y health checks.\"\"\"\n    \n    def __init__(self, id_agente: str, dir_checkpoint: Path):\n        self.id = id_agente\n        self.checkpoint_mgr = CheckpointManager(dir_checkpoint, intervalo_seg=5)\n        self.circuitos: Dict[str, CircuitBreakerSimple] = {}\n        self._estado: Dict[str, Any] = {\"tareas\": 0, \"fallidas\": 0,\n                                        \"ultima\": None, \"memoria\": []}\n        self._activo = False\n        self._lock = threading.Lock()\n        self._hilo_cp: Optional[threading.Thread] = None\n        self._cargar_o_inicializar()\n    \n    def _cargar_o_inicializar(self):\n        try:\n            r = self.checkpoint_mgr.cargar_ultimo(self.id)\n            if r: self._estado = r; logger.info(f\"Restaurado: {r['tareas']} tareas previas\")\n        except Exception as e:\n            logger.warning(f\"Iniciando fresco: {e}\")\n    \n    def registrar_circuito(self, nombre: str, **kw) -> CircuitBreakerSimple:\n        cb = CircuitBreakerSimple(nombre, **kw)\n        self.circuitos[nombre] = cb\n        return cb\n    \n    def _checkpoint_background(self):\n        while self._activo:\n            time.sleep(2)\n            if self.checkpoint_mgr.debe_guardar():\n                try:\n                    with self._lock: copia = dict(self._estado)\n                    self.checkpoint_mgr.guardar(self.id, copia)\n                except Exception as e: logger.error(f\"Error checkpoint: {e}\")\n    \n    def procesar(self, tarea: Dict[str, Any]) -> Dict:\n        inicio = time.time(); tid = tarea.get(\"id\", f\"t{self._estado['tareas']}\")\n        try:\n            with self._lock:\n                self._estado[\"tareas\"] += 1\n                self._estado[\"ultima\"] = {\"id\": tid, \"inicio\": datetime.now().isoformat()}\n            \n            if \"llamada_api\" in tarea:\n                cb = self.circuitos.get(\"api_externa\")\n                if cb and not cb.puede_ejecutar():\n                    raise RuntimeError(\"Circuito abierto\")\n                try:\n                    resultado_api = self._simular_api(tarea[\"llamada_api\"])\n                    if cb: cb.exito()\n                except Exception as e:\n                    if cb: cb.fallo()\n                    raise\n            else:\n                resultado_api = {\"status\": \"no_requerida\"}\n            \n            with self._lock:\n                self._estado[\"memoria\"].append({\"id\": tid, \"ok\": True})\n                if len(self._estado[\"memoria\"]) > 50:\n                    self._estado[\"memoria\"] = self._estado[\"memoria\"][-25:]\n            \n            return {\"id\": tid, \"exito\": True, \"api\": resultado_api,\n                   \"ms\": (time.time() - inicio) * 1000}\n        except Exception as e:\n            with self._lock:\n                self._estado[\"fallidas\"] += 1\n            logger.error(f\"Tarea {tid} fallida: {e}\")\n            return {\"id\": tid, \"exito\": False, \"error\": str(e), \"tipo\": type(e).__name__}\n    \n    def _simular_api(self, params: Dict) -> Dict:\n        time.sleep(random.uniform(0.02, 0.1))\n        if random.random() < 0.35:  # 35% fallas\n            raise random.choice([\n                TimeoutError(\"API timeout\"), ConnectionError(\"Reset by peer\"),\n                RuntimeError(\"HTTP 503\")])()\n        return {\"ok\": True, \"params\": params}\n    \n    def metricas(self) -> Dict:\n        t = self._estado[\"tareas\"]; f = self._estado[\"fallidas\"]\n        return {\"id\": self.id, \"tareas\": t, \"fallidas\": f,\n                \"tasa_exito\": ((t-f)/t if t > 0 else 0),\n                \"circuitos\": {n: cb.estado for n, cb in self.circuitos.items()},\n                \"ultimo_checkpoint\": self.checkpoint_mgr._ultimo.isoformat() if self.checkpoint_mgr._ultimo else None}\n    \n    def iniciar(self):\n        self._activo = True\n        self._hilo_cp = threading.Thread(target=self._checkpoint_background, daemon=True)\n        self._hilo_cp.start(); logger.info(f\"Agente {self.id} iniciado\")\n    \n    def detener(self):\n        self._activo = False\n        if self._hilo_cp: self._hilo_cp.join(timeout=5)\n        self.checkpoint_mgr.guardar(self.id, self._estado)\n        logger.info(f\"Agente {self.id} detenido\")\n\n# Demo completa\nimport shutil\ndir_cp = Path(\"checkpoints_demo\")\nif dir_cp.exists(): shutil.rmtree(dir_cp)\n\nagente = AgenteAutorrecuperable(\"AGT-001\", dir_cp)\nagente.registrar_circuito(\"api_externa\", max_fallos=3, tiempo_abierto=5.0)\nagente.iniciar()\n\nprint(\"\\n--- Fase 1: Procesamiento normal ---\")\nfor i in range(8):\n    r = agente.procesar({\"id\": f\"t{i}\", \"llamada_api\": {\"ep\": f\"/item/{i}\"}})\n    print(f\"  t{i}: {'✓' if r['exito'] else '✗ ' + r.get('tipo','?')}\")\n    time.sleep(0.1)\n\nprint(f\"\\nMétricas: {agente.metricas()}\")\n\nagente.detener()\n\nprint(\"\\n--- Simulación de crash y recuperación ---\")\nagente2 = AgenteAutorrecuperable(\"AGT-001\", dir_cp)\nprint(f\"Estado restaurado: {agente2._estado['tareas']} tareas previas\")",
        "caption": "Crea agente_autorrecuperable.py. El checkpoint background guarda estado automáticamente sin bloquear el hilo principal. La recuperación al inicio (cargar_o_inicializar) es transparente — el agente reanuda donde se quedó."
      },
