        "code": "# Código anti-patrón a refactorizar:\ndef scrapear():\n    url = input(\"URL: \")\n    r = __import__('requests').get(url)\n    if r.status_code == 200:\n        links = []\n        for line in r.text.split(\"\\n\"):\n            if 'href=' in line:\n                start = line.find('href=') + 6\n                end = line.find('\"', start)\n                if end != -1 and line[start:end].startswith('http'):\n                    links.append(line[start:end])\n        with open('links.txt', 'w') as f:\n            f.writelines(l + '\\n' for l in links)\n        print(f'{len(links)} links guardados')\n    else:\n        return False\n    return True\n\n# Objetivos:\n# 1. Separar obtener_html(), extraer_links(), guardar_links()\n# 2. Funciones puras (parseo) vs. impuras (red, archivo)\n# 3. Type hints y docstrings\n# 4. Manejo explícito de errores (no 'return False' silencioso)"
